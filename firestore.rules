rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAnonymousDevice() {
      return isSignedIn() &&
        request.auth.token.firebase.sign_in_provider == "anonymous";
    }

    function isStaffUser() {
      return isSignedIn() && !isAnonymousDevice();
    }

    function currentStaffDoc() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    function isAdminUser() {
      return isStaffUser() && (
        !("role" in currentStaffDoc().data) ||
        currentStaffDoc().data.role == "admin"
      );
    }

    match /staff/{staffId} {
      allow create: if isStaffUser() && request.auth.uid == staffId;
      allow read: if isStaffUser() && (request.auth.uid == staffId || isAdminUser());
      allow update: if isStaffUser() && (request.auth.uid == staffId || isAdminUser());
    }

    match /devices/{deviceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdminUser();
    }

    match /voters/{voterId} {
      allow read: if isSignedIn();
      allow write: if isAdminUser();
    }

    match /elections/{electionId} {
      allow read: if isSignedIn();
      allow write: if isAdminUser();
    }

    match /elections/{electionId}/panels/{panelId} {
      allow read: if isSignedIn();
      allow write: if isAdminUser();
    }

    match /elections/{electionId}/roster/{voterId} {
      allow read: if isSignedIn();
      allow write: if isAdminUser();
    }

    match /elections/{electionId}/ballots/{ballotId} {
      allow read: if isStaffUser();
      allow create: if isSignedIn();
      allow update: if isStaffUser();
      allow delete: if isStaffUser();
    }

    match /publicResults/{electionId} {
      allow read: if true;
      allow write: if isAdminUser();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
