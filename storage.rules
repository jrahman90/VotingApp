rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAnonymousDevice() {
      return isSignedIn() &&
        request.auth.token.firebase.sign_in_provider == "anonymous";
    }

    function isStaffUser() {
      return isSignedIn() && !isAnonymousDevice();
    }

    match /elections/{allPaths=**} {
      allow read: if true;
      allow write: if isStaffUser();
    }

    match /panels/{allPaths=**} {
      allow read: if true;
      allow write: if isStaffUser();
    }

    match /candidates/{allPaths=**} {
      allow read: if true;
      allow write: if isStaffUser();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
